FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    tar \
    gzip \
    curl \
    unzip \
    xz-utils \
    zstd \
    sqlite3 \
    b3sum \
    jq \
    cmake \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

ARG ZIG_VERSION=0.16.0
RUN ARCH=$(uname -m) && \
    ZIG_URL=$(curl -s https://ziglang.org/download/index.json | jq -r --arg version "$ZIG_VERSION" --arg target "$ARCH-linux" '.[$version][$target].tarball') && \
    ZIG_TAR=$(basename "$ZIG_URL") && \
    ZIG_DIR=${ZIG_TAR%.tar.xz} && \
    curl -L "$ZIG_URL" | tar -xJ -C /usr/local && \
    ln -s "/usr/local/$ZIG_DIR/zig" /usr/local/bin/zig

RUN curl -fsSL https://moonstone.sh/install | sh
ENV PATH="/root/.local/bin:${PATH}"

WORKDIR /app

COPY testing-suite/run_lua_tool.sh testing-suite/run_lua_tool.sh
COPY testing-suite/lua-tools testing-suite/lua-tools

CMD ["bash", "testing-suite/run_lua_tool.sh", "registry-builder", "--output-dir", "/output"]
