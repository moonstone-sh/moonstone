FROM alpine:3.20

# 1. Install system dependencies
# - build-base: gcc, make, etc.
# - cmake: for the cmake materializer
# - jq: for selecting the Zig download
# - sqlite, b3sum: for the Moonstone-managed registry builder
# - bash, tar, gzip, curl, xz, unzip: utilities
RUN apk add --no-cache \
    bash \
    ca-certificates \
    tar \
    gzip \
    curl \
    xz \
    unzip \
    zstd \
    sqlite \
    b3sum \
    jq \
    cmake \
    build-base

# 2. Install Zig 0.16.0
ARG ZIG_VERSION=0.16.0
RUN ARCH=$(uname -m) && \
    ZIG_URL=$(curl -s https://ziglang.org/download/index.json | jq -r --arg version "$ZIG_VERSION" --arg target "$ARCH-linux" '.[$version][$target].tarball') && \
    ZIG_TAR=$(basename $ZIG_URL) && \
    ZIG_DIR=${ZIG_TAR%.tar.xz} && \
    curl -L $ZIG_URL | tar -xJ -C /usr/local && \
    ln -s /usr/local/$ZIG_DIR/zig /usr/local/bin/zig

WORKDIR /app

# 3. Copy the whole project and build (invalidated on code change)
COPY . .
RUN zig build

# Entry point: build synthetic registry then run the test suites
CMD ["bash", "-c", "./testing-suite/run_lua_tool.sh registry-builder --output-dir fixtures/sandbox && ./run_all_synthetic_tests.sh"]
