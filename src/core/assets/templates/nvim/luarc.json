{
  "workspace": {
    "library": [
      ".moonstone/env/share/lua/{{lua_ver}}",
      "$VIMRUNTIME/lua"
    ],
    "checkThirdParty": false,
    "useGitIgnore": false,
    "ignoreDir": [
      ".moonstone/env/bin",
      ".moonstone/env/lib",
      ".moonstone/env/include",
      "zig-cache",
      "zig-out",
      ".git"
    ]
  },
  "diagnostics": {
    "globals": ["vim"]
  }
}
